# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# (Required) OpenAI API key for core agent brain (classification + planning + tool calling)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# (Optional, default: gpt-5.2) OpenAI model for core brain
OPENAI_MODEL=gpt-5.2

# (Optional, default: 0.6) Temperature for OpenAI responses (0.0-1.0)
OPENAI_TEMPERATURE=0.2

# (Optional, default: 2048) Max completion tokens for regular OpenAI calls
OPENAI_MAX_COMPLETION_TOKENS=2048

# (Optional, default: 1536) Max completion tokens for structured JSON calls
OPENAI_STRUCTURED_MAX_COMPLETION_TOKENS=1536

# (Optional, default: 2048) Max completion tokens for tool-planning loop
OPENAI_PLAN_MAX_COMPLETION_TOKENS=2048

# (Required) Anthropic API key for Claude frontend report formatting
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# (Optional, default: claude-sonnet-4-6) Model ID to use
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6

# (Optional, default: 0.6) Temperature for LLM responses (0.0-1.0)
# Lower = more deterministic, Higher = more creative
ANTHROPIC_TEMPERATURE=0.3

# (Optional, default: 2048) Max output tokens for Claude formatter calls
ANTHROPIC_MAX_TOKENS=2048

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Server Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# (Optional, default: 3000) HTTP server port
PORT=3000

# (Optional, default: development) Environment mode
# Options: development, production, test
NODE_ENV=development

# (Optional, default: http://localhost:3001) Frontend URL for CORS
WEB_ORIGIN=http://localhost:3001

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Session & Storage Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# (Optional, default: 7) Session TTL in days
SESSION_TTL_DAYS=7

# (Required in production, min 32 chars) Secret used to HMAC-hash session tokens at rest
# Generate a strong random token: $(openssl rand -base64 32)
# SECURITY: Must be different in each environment (dev, staging, production)
SESSION_TOKEN_SECRET=your-super-secret-token-at-least-32-chars-long-change-in-prod

# (Optional, default: session) Cookie name
SESSION_COOKIE_NAME=session

# (Optional, default: lax) Cookie SameSite policy: lax | strict | none
SESSION_COOKIE_SAME_SITE=lax

# (Optional) Cookie domain (set only when needed)
# SESSION_COOKIE_DOMAIN=.example.com

# (Optional, default: 30) Session rotation interval in minutes
SESSION_ROTATE_INTERVAL_MINUTES=30

# (Optional, default: ./data) Directory for storing user data and profiles
DATA_DIR=./data

# (Optional) Postgres DSN for persistent storage (required in production)
# Example:
# DATABASE_URL=postgresql://user:password@localhost:5432/financial_agent
DATABASE_URL=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Development Features (Disable in Production)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# (Optional, default: false) Enable dev-only data injection endpoints
# SECURITY: Keep false in production
ENABLE_DEV_INJECTION=false

# (Optional, default: change-me) Admin token for dev endpoints
# Required only if ENABLE_DEV_INJECTION=true
DEV_ADMIN_TOKEN=change-me

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Logging Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# (Optional, default: info) Log level
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
