generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ANALYST
  ADMIN
}

enum DocumentSource {
  USER_UPLOAD
  AGENT_GENERATED
  SYSTEM
}

enum DocumentKind {
  PDF
  EXCEL
  CSV
  IMAGE
  TEXT
  REPORT
  STATEMENT
  OTHER
}

enum DocumentStatus {
  PARSED
  INDEXED
  FAILED
}

model User {
  id                        String   @id @db.VarChar(128)
  name                      String   @db.VarChar(200)
  email                     String   @unique @db.VarChar(320)
  passwordHash              String   @db.VarChar(200)
  role                      UserRole @default(USER)
  injectedProfile           Json?
  injectedIntake            Json?
  latestDiagnosticProfileId String?  @db.VarChar(200)
  latestDiagnosticCompletedAt DateTime?
  panelState                Json?
  sheets                    Json?
  knowledgeBaseScore        Int      @default(0)
  knowledgeScore            Int      @default(0)
  knowledgeHistory          Json?
  knowledgeLastUpdated      DateTime @default(now())
  memoryBlob                Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  sessions Session[]
  profiles FinancialProfile[]
  documents UserDocument[]
  vectorStore UserVectorStore?

  @@index([createdAt])
  @@index([knowledgeScore])
}

model UserVectorStore {
  userId        String   @id @db.VarChar(128)
  vectorStoreId String   @db.VarChar(200)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserDocument {
  id             String         @id @db.VarChar(128)
  userId         String         @db.VarChar(128)
  name           String         @db.VarChar(300)
  kind           DocumentKind
  source         DocumentSource @default(USER_UPLOAD)
  mimeType       String?        @db.VarChar(200)
  sizeBytes      Int?
  textPreview    String?
  extractedText  String?
  summary        Json?
  structuredData Json?
  openaiFileId   String?        @db.VarChar(200)
  vectorStoreId  String?        @db.VarChar(200)
  status         DocumentStatus @default(PARSED)
  error          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, kind])
}

model Session {
  tokenHash       String   @id @db.VarChar(128)
  userId          String   @db.VarChar(128)
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  lastSeenAt      DateTime @default(now())
  rotatedFromHash String?  @db.VarChar(128)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model FinancialProfile {
  id        String   @id @db.VarChar(200)
  userId    String   @db.VarChar(128)
  payload   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}
