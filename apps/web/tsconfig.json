{
    "compilerOptions": {
      "target": "ES2020",
      "lib": ["dom", "dom.iterable", "esnext"],
      "allowJs": true,
      "skipLibCheck": true,
      "strict": true,
      "noEmit": true,
  
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
  
      "resolveJsonModule": true,
      "isolatedModules": true,
      "jsx": "preserve",
  
      "incremental": true,
      "esModuleInterop": true,
  
      "baseUrl": ".",
      "paths": {
        "@/*": ["./*"]
      },
  
      "plugins": [{ "name": "next" }]
    },
    "include": [
      "next-env.d.ts",
      "**/*.ts",
      "**/*.tsx",
      ".next/types/**/*.ts"
    ],
    "exclude": ["node_modules"]
  }
  